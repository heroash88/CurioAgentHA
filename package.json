{
  "name": "curio-robot",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev": "npm run build:worker && vite",
    "start": "npm run build:worker && vite --host",
    "build:worker": "node ./scripts/build-worker.mjs",
    "build": "npm run build:worker && node --max-old-space-size=8192 ./node_modules/vite/bin/vite.js build",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "prepare": "husky",
    "preview": "npm run build:worker && vite preview --host",
    "profile:idle": "node ./scripts/idle-profile.mjs",
    "test": "vitest --run --config vitest.config.ts"
  },
  "dependencies": {
    "@google/genai": "^1.47.0",
    "@mediapipe/tasks-vision": "^0.10.34",
    "firebase": "^12.11.0",
    "framer-motion": "^12.26.2",
    "lucide-react": "^0.562.0",
    "openwakeword-js": "^0.1.27",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "esbuild": "^0.28.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.3"
  }
}
